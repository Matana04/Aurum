// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema


generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model Usuarios {
  id        String    @id @default(uuid())
  nome      String
  email     String    @unique
  senha     String    
  
  despesas  Despesas[]
  metas     Metas[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("usuarios")
}

model Despesas {
  id        String   @id @default(uuid())
  titulo    String
  categoria String?
  valor     Decimal  @db.Decimal(10, 2)
  data      DateTime 
  
  usuarioId String
  usuario   Usuarios @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("despesas")
}

model Metas {
  id               String   @id @default(uuid())
  titulo           String
  valor            Decimal  @db.Decimal(10, 2)
  valorAcumulado   Decimal  @db.Decimal(10, 2) @default(0)
  dataInicio       DateTime
  dataFinal        DateTime
  
  usuarioId        String
  usuario          Usuarios @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("metas")
}
